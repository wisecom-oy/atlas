{
  "name": "@wisecom/atlas-core",
  "version": "2.0.0-beta.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias --project tsconfig.json -f",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@wisecom/atlas-types": "workspace:*",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "htmlparser2": "^12.0.0",
    "inversify": "^7.11.0",
    "reflect-metadata": "^0.2.2"
  }
}
