{
  "name": "@atlas/cli",
  "version": "1.2.3",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlas": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias --project tsconfig.json -f",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@atlas/types": "workspace:*",
    "@atlas/core": "workspace:*",
    "@atlas/m365-graph": "workspace:*",
    "@atlas/s3": "workspace:*",
    "@atlas/outlook": "workspace:*",
    "@atlas/onedrive": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inversify": "^7.11.0",
    "reflect-metadata": "^0.2.2"
  }
}
