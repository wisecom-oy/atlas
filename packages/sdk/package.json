{
  "name": "@wisecom/atlas-sdk",
  "version": "2.0.0-beta.0",
  "description": "Programmatic API for embedding Atlas M365 backup and restore in Node.js applications.",
  "license": "Apache-2.0",
  "author": "Wisecom Oy <https://wisecom.fi>",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "htmlparser2": "^12.0.0",
    "inversify": "^7.11.0",
    "mimetext": "^3.0.28",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@wisecom/atlas-types": "workspace:*",
    "@wisecom/atlas-core": "workspace:*",
    "@wisecom/atlas-m365-graph": "workspace:*",
    "@wisecom/atlas-s3": "workspace:*",
    "@wisecom/atlas-outlook": "workspace:*",
    "@wisecom/atlas-onedrive": "workspace:*",
    "@wisecom/atlas-sharepoint": "workspace:*"
  }
}
