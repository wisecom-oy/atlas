{
  "name": "m365-atlas",
  "version": "1.2.0",
  "description": "An open-source CLI backup engine for Microsoft 365 mailboxes, designed with per-tenant encryption, content-addressed storage, and efficient delta synchronization for scalable, secure backups.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./sdk": {
      "import": {
        "types": "./dist/sdk.d.mts",
        "default": "./dist/sdk.mjs"
      }
    }
  },
  "bin": {
    "atlas": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/sdk.ts src/cli.ts --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "keywords": [
    "m365",
    "backup",
    "email",
    "o365",
    "s3",
    "minio"
  ],
  "author": "Miika Oja-Kaukola",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miikaok/atlas.git"
  },
  "homepage": "https://github.com/miikaok/atlas#readme",
  "bugs": {
    "url": "https://github.com/miikaok/atlas/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": "prettier --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inversify": "^7.11.0",
    "mimetext": "^3.0.28",
    "reflect-metadata": "^0.2.2"
  }
}
